# =============================================================================
# cert-manager + easyDNS: Complete Kubernetes Deployment
# =============================================================================
#
# FILE: 01-secret.yaml
# PURPOSE: Stores your easyDNS API credentials securely in Kubernetes.
#
# ⚠️  SECURITY: Never commit this file to Git with real credentials.
#     Use a secret manager (Vault, Sealed Secrets, AWS SSM) in production.
#
# HOW TO APPLY:
#   1. Edit this file, replacing the placeholder values below.
#   2. kubectl apply -f 01-secret.yaml
#
# ALTERNATIVELY, create the secret from the command line (no file needed):
#   kubectl create secret generic easydns-credentials \
#     --namespace cert-manager \
#     --from-literal=api-token='your-actual-token' \
#     --from-literal=api-key='your-actual-key'
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: easydns-credentials
  namespace: cert-manager   # Must be in the cert-manager namespace
  labels:
    app: cert-manager-webhook-easydns
type: Opaque

# stringData lets you write plain text — Kubernetes automatically base64-encodes it.
# If you use "data:" instead, values must already be base64-encoded.
stringData:
  api-token: "PASTE_YOUR_EASYDNS_API_TOKEN_HERE"  # ← REQUIRED: Your easyDNS API Token
  api-key: "PASTE_YOUR_EASYDNS_API_KEY_HERE"      # ← REQUIRED: Your easyDNS API Key
