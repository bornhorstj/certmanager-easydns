# Copy to secrets.yml and fill in your values.
# secrets.yml is gitignored — never commit credentials.
#
# Usage:
#   ansible-playbook -i localhost, deploy.yml -e @secrets.yml

# EasyDNS API credentials
# Find these at: https://cp.easydns.com → Account → API Access
easydns_api_token: ""
easydns_api_key: ""

# Let's Encrypt account email (expiry notifications sent here)
letsencrypt_email: ""

# Domain to issue a certificate for
# DNS-01 supports wildcards — both apex and wildcard are requested by default
cluster_domain: ""

# Container registry where the webhook image is pushed
webhook_image_repository: "ghcr.io/bornhorstj/certmanager-easydns"
